extends ../layout

block content
  h1 #{title} 
  
  div.d-flex.justify-content-end.mb-3
    a.btn.btn-violeta.mr-2(href="/pacientes/nuevo") Registrar nuevo paciente
  hr

  if admisiones && admisiones.length > 0
    div.table-responsive
      table.table.table-striped.table-hover.table-bordered
        thead.thead-dark
          tr
            th ID Admisión 
            th DNI Paciente 
            th Nombre Paciente 
            th Fecha Admisión 
            th Tipo 
            th Estado 
            th Acciones 
        tbody
          each admision in admisiones
            tr
              td= admision.id
              td= admision.paciente_dni
              td #{admision.paciente_apellido}, #{admision.paciente_nombre}
              td= admision.fecha_admision ? new Date(admision.fecha_admision).toLocaleDateString() : 'N/A'
              td= admision.tipo_admision
              td 
                span(class=`badge badge-${admision.estado_admision === 'Activa' ? 'success' : 'secondary'}`)= admision.estado_admision
              td
                div.d-flex.flex-column.align-items-stretch
                  a(href=`/admisiones/${admision.id}` class="btn btn-info btn-sm mb-1") Ver Detalles
                  if admision.evaluacion_enfermeria_id
                    a(href=`/evaluaciones-enfermeria/${admision.evaluacion_enfermeria_id}` class="btn btn-success btn-sm mb-1") Eval. Enfermería
                  else
                    a(href=`/evaluaciones-enfermeria/admision/${admision.id}/nueva` class="btn btn-outline-secondary btn-sm mb-1") Cargar Enfermería
                  if admision.evaluacion_medica_id
                    a(href=`/evaluaciones-medicas/${admision.evaluacion_medica_id}` class="btn btn-primary btn-sm mb-1") Eval. Médica
                  else
                    a(href=`/evaluaciones-medicas/admision/${admision.id}/nueva` class="btn btn-outline-secondary btn-sm mb-1") Cargar Médica
                  
  else
    p.mt-3 No se encontraron admisiones en el sistema.
