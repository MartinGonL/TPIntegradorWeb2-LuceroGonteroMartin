extends ../layout

block content
  h1 #{title} 

  // Información de Contexto
  if admision && paciente
    div.row.mt-3.mb-3
      div.col-md-6
        div.card
          div.card-header Detalles de la Admisión 
          div.card-body
            p.card-text #[strong ID de Admisión:] #{admision.id} 
            p.card-text #[strong Fecha de Admisión:] #{admision.fecha_admision ? new Date(admision.fecha_admision).toLocaleString() : 'N/A'} 
      div.col-md-6
        div.card
          div.card-header Detalles del Paciente 
          div.card-body
            p.card-text #[strong Nombre:] #{paciente.nombre} #{paciente.apellido} 
            p.card-text #[strong DNI:] #{paciente.dni}
  if evaluacionMedica
    div.card.mt-3.mb-3
      div.card-header Evaluación Médica Vinculada 
      div.card-body
        p.card-text #[strong ID Evaluación Médica:] #{evaluacionMedica.id} 
        p.card-text #[strong Fecha Evaluación Médica:] #{evaluacionMedica.fecha_evaluacion ? new Date(evaluacionMedica.fecha_evaluacion).toLocaleString() : 'N/A'} 
        p.card-text
          a.btn.btn-violeta.btn-sm.mr-2(href=`/evaluaciones-medicas/${evaluacionMedica.id}`) Ver Detalle de Evaluación Médica 
          a.btn.btn-violeta.btn-sm(href=`/evaluaciones-medicas/${evaluacionMedica.id}/editar`) Editar Evaluación Médica 

  if errors && errors.length > 0
    div.alert.alert-danger.mt-3
      h4 Errores: 
      ul
        each error in errors
          li= error.msg 
  
  if evaluacion && evaluacion.id 
    form(method="POST" action=`/evaluaciones-enfermeria/${evaluacion.id}/actualizar`)
      
      h3.mt-4 Información General
      div.form-group.mt-3
        label(for="enfermero_id") ID Enfermero/a:
        input(type="text" id="enfermero_id" name="enfermero_id" value=evaluacion.enfermero_id required class="form-control")

      div.form-group.mt-3
        label(for="motivo_internacion_actual") Motivo de Internación Actual:
        textarea#motivo_internacion_actual.form-control(name="motivo_internacion_actual" rows="3" required) #{evaluacion.motivo_internacion_actual}
      
      h3.mt-4 Signos Vitales
      div.row
        div.col-md-4.form-group.mt-3
          label(for="signos_vitales_ta") Presión Arterial (TA):
          input(type="text" id="signos_vitales_ta" name="signos_vitales_ta" value=evaluacion.signos_vitales_ta || '' class="form-control" placeholder="ej., 120/80")
        div.col-md-4.form-group.mt-3
          label(for="signos_vitales_fc") Frecuencia Cardíaca (FC):
          input(type="number" id="signos_vitales_fc" name="signos_vitales_fc" value=evaluacion.signos_vitales_fc || '' class="form-control" placeholder="lpm")
        div.col-md-4.form-group.mt-3
          label(for="signos_vitales_fr") Frecuencia Respiratoria (FR):
          input(type="number" id="signos_vitales_fr" name="signos_vitales_fr" value=evaluacion.signos_vitales_fr || '' class="form-control" placeholder="rpm")
      div.row
        div.col-md-4.form-group.mt-3
          label(for="signos_vitales_temp") Temperatura (°C):
          input(type="number" step="0.1" id="signos_vitales_temp" name="signos_vitales_temp" value=evaluacion.signos_vitales_temp || '' class="form-control" placeholder="ej., 36.5")
        div.col-md-4.form-group.mt-3
          label(for="signos_vitales_sato2") Saturación O2 (%):
          input(type="number" id="signos_vitales_sato2" name="signos_vitales_sato2" value=evaluacion.signos_vitales_sato2 || '' class="form-control" placeholder="%")

      h3.mt-4 Observaciones Adicionales
      div.form-group.mt-3
        label(for="observaciones_adicionales") Observaciones Adicionales:
        textarea#observaciones_adicionales.form-control(name="observaciones_adicionales" rows="4") #{evaluacion.observaciones_adicionales || ''}

      button(type="submit" class="btn btn-primary mt-3") Actualizar Evaluación 
      a(href=`/evaluaciones-enfermeria/${evaluacion.id}` class="btn btn-secondary mt-3 ml-2") Cancelar 
    p Datos de la evaluación de enfermería no disponibles para edición.
    a(href="/admisiones" class="btn btn-secondary mt-3") Volver a Lista de Admisiones 